# Copy to apps/web/.env.local and fill in from your Supabase project settings.
# (Project Settings → API). Never commit .env.local.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by API routes (service role bypasses RLS). NEVER expose.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Where magic-link / OAuth redirects land in production (e.g. https://onward.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
