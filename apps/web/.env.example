# Copy to apps/web/.env.local (or .env) and fill in. Never commit real values.

# ── Clerk (auth) — from the Clerk dashboard → API Keys ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/account
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/account

# ── Supabase (Postgres data store only — not auth) ──
# IMPORTANT: use the SERVICE ROLE key (sb_secret_… or the service_role JWT),
# NOT the publishable/anon key — server routes need it to write.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Gemini (offer-letter extraction; free tier from Google AI Studio) ──
# Enables robust any-format + scanned-PDF extraction. If unset, the app falls
# back to the built-in heuristic parser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Public site URL (prod: your https://<project>.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google Analytics 4 (usage + event tracking) ──
# Your GA4 Measurement ID (looks like G-XXXXXXXXXX), from GA Admin → Data Streams.
# When unset, no analytics script loads (clean local dev / preview builds).
NEXT_PUBLIC_GA_ID=
